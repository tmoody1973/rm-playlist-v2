{
  "name": "rm-playlist-v2",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Radio Milwaukee playlist platform v2 — single-tenant operator dashboard + embeddable widgets",
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/*"
  ],
  "scripts": {
    "typecheck": "bun --filter='@rm/*' run typecheck",
    "test": "bun --filter='@rm/*' run test",
    "lint": "bun --filter='@rm/*' run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\" --ignore-path .prettierignore",
    "format:check": "prettier --check \"**/*.{ts,tsx,md,json}\" --ignore-path .prettierignore"
  },
  "devDependencies": {
    "@trigger.dev/build": "4.4.4",
    "@types/node": "^22.10.0",
    "eslint": "^9.18.0",
    "prettier": "^3.4.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.20.0"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "dependencies": {
    "@trigger.dev/sdk": "4.4.4",
    "convex": "^1.17.0"
  }
}
